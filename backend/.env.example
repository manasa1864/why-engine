# ============================================
# WHY ENGINE — ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values
# ============================================

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Supabase (get from: supabase.com → Project Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-secret-key

# JWT Authentication
JWT_SECRET=change-this-to-a-random-secret-string-at-least-32-chars
JWT_EXPIRE=7d

# Judge0 Code Execution (free public instance — no API key needed)
JUDGE0_API_URL=https://ce.judge0.com
JUDGE0_TIMEOUT=30000

# Groq AI Reasoning (get from: console.groq.com → API Keys)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_TIMEOUT=60000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_GENERAL=100
RATE_LIMIT_MAX_CODE=30
RATE_LIMIT_MAX_AUTH=20
